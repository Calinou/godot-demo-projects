[gd_resource type="ShaderMaterial" load_steps=2 format=2]


[sub_resource type="Shader" id=1]

_code = {
"fragment": "//there is no albedo (all shading is normal)
uniform color col;
COLOR=col;
//sample normal texture
vec4 ntex = tex(TEXTURE,UV);
//take the alpha from the normal texture
COLOR.a=ntex.a;
//adjust normalmap from [0..1] to [-1..1]
ntex.rgb = ntex.rgb * vec3(-2,-2,1) - vec3(-1,-1,0);
//half size of the tile 
vec2 tile_vec=vec2(47,22);
//rotation to convert the normal to pseudo 3d coordinates
//this could be optimized
float r = asin(tile_vec.y / tile_vec.x);
mat3 rot_mat = mat3( vec3(1,0,0), vec3(0,cos(r),-sin(r)), vec3(0,sin(r),cos(r)));

//pass the normal
NORMAL =  rot_mat * ntex.rgb;




",
"fragment_ofs": 0,
"light": "//apply the normal as simple diffuse (same as default code)
vec3 light_normal = normalize(vec3(LIGHT_VEC,-LIGHT_HEIGHT));
LIGHT=LIGHT_COLOR*COLOR*max(dot(-light_normal,NORMAL),0.0);
//substract light position to be always aligned to the bottom of the sprite
//this makes lighting on it look like a billboard
LIGHT_VEC.y-=VAR1.y;
",
"light_ofs": 0,
"vertex": "// pass the local sprite coordinates through a varying
// the red cross in the sprite is the 0,0
VAR1.xy=SRC_VERTEX;",
"vertex_ofs": 0
}

[resource]

shader/shader = SubResource( 1 )
shader/shading_mode = 0
shader_param/col = Color( 1, 0.836638, 0.693806, 1 )
